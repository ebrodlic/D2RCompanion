<Window x:Class="D2RPriceChecker.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:D2RPriceChecker.Views"
        mc:Ignorable="d"
        Title="SettingsWindow" Height="400" Width="600">
    <Grid>
        <StackPanel Margin="10" Orientation="Vertical">
            <CheckBox IsChecked="{Binding AutoCheckForUpdates}" Content="Automatically check for updates" />
            <CheckBox IsChecked="{Binding SaveImagesToDisk}" Content="Save images to disk" />
        </StackPanel>
        

    </Grid>
</Window>

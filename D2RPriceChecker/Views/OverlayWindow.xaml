<Window
    x:Class="D2RPriceChecker.Views.OverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:D2RPriceChecker.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="OverlayWindow"
    Width="800"
    Height="600"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowState="Maximized"
    WindowStyle="None"
    mc:Ignorable="d">

    <!--  Fullscreen Dark Overlay  -->
    <Grid x:Name="Root" Background="#80000000">
        <!--  Click outside handler  -->
        <Grid.InputBindings>
            <!--  optional  -->
        </Grid.InputBindings>

        <!--  Centered content  -->
        <Border
            x:Name="ContentPanel"
            Width="500"
            Padding="10"
            HorizontalAlignment="Center"
            VerticalAlignment="Stretch"
            Background="#131415"
            CornerRadius="8"
            MouseDown="ContentPanel_MouseDown">
            <Grid>
                <!--  Main Content: OCR, prices, trades  -->
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  ================= ITEM DESCRIPTION =================  -->
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  TITLE  -->
                        <TextBlock
                            Grid.Row="0"
                            Margin="0,0,0,6"
                            FontSize="12"
                            Foreground="#888888"
                            Text="ITEM DESCRIPTION" />

                        <!--  CONTENT  -->
                        <ScrollViewer
                            Grid.Row="1"
                            MaxHeight="250"
                            VerticalScrollBarVisibility="Hidden">
                            <ItemsControl ItemsSource="{Binding OcrLines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock
                                            Margin="0,0,0,2"
                                            FontSize="12"
                                            Foreground="White"
                                            Text="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <!--  SEPARATOR  -->
                        <Border
                            Grid.Row="2"
                            Height="1"
                            Margin="0,10,0,0"
                            Background="#2A2A2A"
                            Opacity="0.6" />

                    </Grid>

                    <!--  ================= PRICE SUMMARY =================  -->
                    <Grid
                        Grid.Row="1"
                        Margin="0,10,0,0"
                        VerticalAlignment="Center">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Margin="0,0,0,6"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="#888888"
                            Text="PRICE SUMMARY (IN IST)" />

                        <Grid Grid.Row="1">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50" />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  ================= FLOOR =================  -->
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="Gray"
                                Text="Floor" />

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="White"
                                Text="{Binding FloorDisplay}"
                                TextAlignment="Right" />

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="2"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="LightGray"
                                Text="{Binding FloorEstimateDisplay}" />


                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="3"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="#555555"
                                Text="bottom 15%"
                                TextAlignment="Right" />


                            <!--  ================= TYPICAL =================  -->
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="Gray"
                                Text="Typical" />

                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="White"
                                Text="{Binding TypicalDisplay}"
                                TextAlignment="Right" />

                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="2"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="LightGray"
                                Text="{Binding TypicalEstimateDisplay}" />

                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="3"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="#555555"
                                Text="median"
                                TextAlignment="Right" />


                            <!--  ================= GOOD =================  -->
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="Gray"
                                Text="Good" />

                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="White"
                                Text="{Binding GoodDisplay}"
                                TextAlignment="Right" />

                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="2"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="LightGray"
                                Text="{Binding GoodEstimateDisplay}" />

                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="3"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="#555555"
                                Text="top 25%"
                                TextAlignment="Right" />


                            <!--  ================= HIGH =================  -->
                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="Gray"
                                Text="High" />

                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="White"
                                Text="{Binding HighDisplay}"
                                TextAlignment="Right" />

                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="2"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="LightGray"
                                Text="{Binding HighEstimateDisplay}" />

                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="3"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="#555555"
                                Text="top 5%"
                                TextAlignment="Right" />

                        </Grid>

                        <!--  SEPARATOR  -->
                        <Border
                            Grid.Row="2"
                            Height="1"
                            Margin="0,10,0,0"
                            Background="#2A2A2A"
                            Opacity="0.6" />

                    </Grid>

                    <!--  ================= RECENT TRADES =================  -->
                    <Grid Grid.Row="2" Margin="0,10,0,0">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  TITLE  -->
                        <TextBlock
                            Grid.Row="0"
                            Margin="0,0,0,6"
                            FontSize="12"
                            Foreground="#888888"
                            Text="RECENT TRADES" />

                        <!--  SCROLL CONTENT  -->
                        <ScrollViewer
                            x:Name="TradesScrollViewer"
                            Grid.Row="1"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Hidden">

                            <ItemsControl ItemsSource="{Binding Trades}">

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>

                                        <Border
                                            Margin="0,2"
                                            Padding="4"
                                            Background="#202224"
                                            BorderBrush="Gray"
                                            BorderThickness="1">

                                            <Grid>

                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <!--  ================= HEADER =================  -->
                                                <Grid Grid.Row="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">

                                                        <TextBlock
                                                            FontWeight="Bold"
                                                            Foreground="White"
                                                            Text="{Binding Amount}" />

                                                        <TextBlock Foreground="White" Text=" x " />

                                                        <TextBlock
                                                            FontWeight="Bold"
                                                            Foreground="White"
                                                            Text="{Binding ItemName}" />
                                                    </StackPanel>

                                                    <ItemsControl
                                                        Grid.Column="1"
                                                        Margin="4,0"
                                                        ItemsSource="{Binding Labels}">

                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal" />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>

                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border
                                                                    Margin="1,0"
                                                                    Padding="2"
                                                                    Background="#333"
                                                                    CornerRadius="3">

                                                                    <TextBlock
                                                                        FontSize="10"
                                                                        Foreground="LightGray"
                                                                        Text="{Binding}" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>

                                                    </ItemsControl>

                                                    <TextBlock
                                                        Grid.Column="2"
                                                        FontSize="10"
                                                        Foreground="Gray"
                                                        Opacity="0.7"
                                                        Text="{Binding TimeAgo}" />
                                                </Grid>

                                                <!--  ================= ATTRIBUTES =================  -->
                                                <ItemsControl
                                                    Grid.Row="1"
                                                    Margin="4,2,0,0"
                                                    ItemsSource="{Binding Attributes}">

                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock
                                                                Margin="0,0,0,1"
                                                                FontSize="11"
                                                                Foreground="White"
                                                                Text="{Binding}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>

                                                </ItemsControl>

                                                <!--  ================= PRICES =================  -->
                                                <ItemsControl
                                                    Grid.Row="2"
                                                    Margin="0,2,0,0"
                                                    ItemsSource="{Binding Prices}">

                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>

                                                            <StackPanel Margin="0,1,0,0" Orientation="Horizontal">

                                                                <TextBlock
                                                                    Width="26"
                                                                    Foreground="White"
                                                                    Text="{Binding Quantity}" />

                                                                <TextBlock Foreground="White" Text="x " />

                                                                <TextBlock Foreground="White" Text="{Binding Name}" />

                                                                <TextBlock
                                                                    Margin="6,0,0,0"
                                                                    Foreground="LightGray"
                                                                    Text="{Binding Price}" />

                                                            </StackPanel>

                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>

                                                </ItemsControl>

                                            </Grid>
                                        </Border>

                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>

                            </ItemsControl>

                        </ScrollViewer>
                    </Grid>

                </Grid>

                <!--  Buttons Overlay  -->
                <StackPanel
                    Margin="0,4,4,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Orientation="Horizontal">
                    <Button
                        Width="20"
                        Height="20"
                        Margin="0,0,4,0"
                        Background="#8B0000"
                        BorderThickness="0"
                        Click="HelpButton_Click"
                        Content="?"
                        FontWeight="Bold"
                        Foreground="White"
                        ToolTip="Help" />

                    <Button
                        Width="20"
                        Height="20"
                        Margin="0,0,4,0"
                        Background="#8B0000"
                        BorderThickness="0"
                        Click="CloseButton_Click"
                        Content="✕"
                        FontWeight="Bold"
                        Foreground="White"
                        ToolTip="Close" />
                </StackPanel>
            </Grid>

        </Border>

    </Grid>
</Window>

<UserControl
    x:Class="D2RCompanion.UI.Views.PriceCheckView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:D2RCompanion.UI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>

        <!--  Main panel  -->
        <Border
            Width="640"
            Height="480"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="#2B2B2B"
            BorderBrush="#111"
            BorderThickness="1"
            CornerRadius="6">

            <Grid>

                <!--  Layout  -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <!--  TOP BAR  -->
                    <RowDefinition Height="*" />
                    <!--  CONTENT  -->
                </Grid.RowDefinitions>

                <!--  ================= TOP BAR =================  -->
                <Grid Grid.Row="0" Background="#1F1F1F">

                    <TextBlock
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Price Check" />

                    <Button
                        Width="32"
                        Height="26"
                        Margin="0,0,8,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="#333"
                        BorderThickness="0"
                        Click="Close_Click"
                        Content="✕"
                        Cursor="Hand"
                        Foreground="White" />
                </Grid>

                <!--  ================= CONTENT =================  -->
                <Grid Grid.Row="1">

                    <Border
                        Margin="16"
                        Padding="16"
                        Background="#3A3A3A"
                        CornerRadius="4">

                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="Price Check View" />

                    </Border>

                </Grid>

            </Grid>
        </Border>

    </Grid>
</UserControl>

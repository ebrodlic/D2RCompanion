<UserControl
    x:Class="D2RCompanion.UI.Views.PriceCheckView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:D2RCompanion.UI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sections="clr-namespace:D2RCompanion.UI.Views.PriceCheck.Sections"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Border
        x:Name="ContentPanel"
        Width="500"
        HorizontalAlignment="Center"
        VerticalAlignment="Stretch"
        Background="#131415"
        CornerRadius="8"
        MouseDown="ContentPanel_MouseDown">
        <Grid>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Title and close  -->
                <Grid Grid.Row="0">
                    <TextBlock
                        Grid.Column="0"
                        Padding="4,2,4,2"
                        Background="#3b0f0e"
                        FontSize="14"
                        Foreground="White"
                        Text="Price Check"
                        TextAlignment="Center" />
                    <TextBlock
                        Margin="0,0,2,0"
                        Padding="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="#000000"
                        Cursor="Hand"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="14"
                        Foreground="White"
                        MouseLeftButtonUp="CloseButton_Click"
                        Text="&#xE711;" />
                </Grid>

                <!--  Main Content: OCR, prices, price prediction, trades  -->
                <Grid Grid.Row="1" Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <sections:ItemDescriptionView Grid.Row="0" />

                    <Border
                        Grid.Row="1"
                        Height="1"
                        Margin="0,10,0,0"
                        Background="#2A2A2A"
                        Opacity="0.6" />

                    <sections:PriceSummaryView Grid.Row="2" />

                    <Border
                        Grid.Row="3"
                        Height="1"
                        Margin="0,10,0,0"
                        Background="#2A2A2A"
                        Opacity="0.6" />

                    <sections:PricePredictionView Grid.Row="4" />

                    <Border
                        Grid.Row="5"
                        Height="1"
                        Margin="0,10,0,0"
                        Background="#2A2A2A"
                        Opacity="0.6" />

                    <sections:TradesView Grid.Row="6" />

                    <TextBlock
                        Grid.Row="7"
                        FontSize="13"
                        Foreground="#BBBBBB"
                        Text="Placeholder"
                        TextAlignment="Right" />
                </Grid>
            </Grid>


            <Popup
                HorizontalOffset="10"
                Placement="Right"
                PlacementTarget="{Binding ElementName=InfoButton}"
                StaysOpen="True"
                VerticalOffset="0">
                <Popup.Style>
                    <Style TargetType="Popup">
                        <Setter Property="IsOpen" Value="False" />

                        <Style.Triggers>

                            <!--  Hover  -->
                            <DataTrigger Binding="{Binding ElementName=InfoButton, Path=IsMouseOver}" Value="True">
                                <Setter Property="IsOpen" Value="True" />
                            </DataTrigger>

                            <!--  Pinned  -->
                            <DataTrigger Binding="{Binding IsRuneInfoPinned}" Value="True">
                                <Setter Property="IsOpen" Value="True" />
                            </DataTrigger>

                        </Style.Triggers>
                    </Style>
                </Popup.Style>

                <!--  content  -->
                <Border
                    Padding="10"
                    Background="#FF1A1A1A"
                    BorderBrush="#444"
                    BorderThickness="1"
                    CornerRadius="6">

                    <StackPanel>

                        <!--  Title  -->
                        <TextBlock
                            Margin="0,0,0,6"
                            FontSize="12"
                            Foreground="#AAAAAA"
                            Text="RUNE VALUES (IN IST)" />

                        <!--  Dynamic list  -->
                        <ItemsControl ItemsSource="{Binding Statistics.RuneValues}">

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>

                                    <!--  Row  -->
                                    <Grid Margin="0,1">

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="50" />
                                        </Grid.ColumnDefinitions>

                                        <!--  Short name  -->
                                        <TextBlock
                                            Grid.Column="0"
                                            FontSize="13"
                                            Foreground="White"
                                            Text="{Binding ShortName}" />

                                        <!--  Value  -->
                                        <TextBlock
                                            Grid.Column="1"
                                            FontSize="13"
                                            Foreground="#BBBBBB"
                                            Text="{Binding IstValue, StringFormat={}{0:0.##}}"
                                            TextAlignment="Right" />

                                    </Grid>

                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>



    </Border>

</UserControl>

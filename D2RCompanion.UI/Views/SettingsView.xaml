<UserControl
    x:Class="D2RCompanion.UI.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:D2RCompanion.UI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid>

        <Border
            Width="700"
            Height="500"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="#2B2B2B"
            BorderBrush="#111"
            BorderThickness="1"
            CornerRadius="6">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <!--  TOP BAR  -->
                    <RowDefinition Height="*" />
                    <!--  BODY  -->
                </Grid.RowDefinitions>

                <!--  ================= TOP BAR =================  -->
                <Grid Grid.Row="0" Background="#1F1F1F">

                    <TextBlock
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Settings" />

                    <Button
                        Width="32"
                        Height="26"
                        Margin="0,0,8,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="#333"
                        BorderThickness="0"
                        Click="Close_Click"
                        Content="✕"
                        Cursor="Hand"
                        Foreground="White" />
                </Grid>

                <!--  ================= BODY =================  -->
                <Grid Grid.Row="1">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  LEFT TABS  -->
                    <StackPanel Grid.Column="0" Background="#1F1F1F">

                        <Button
                            Height="40"
                            Background="Transparent"
                            BorderThickness="0"
                            Content="General"
                            Foreground="White" />
                        <Button
                            Height="40"
                            Background="Transparent"
                            BorderThickness="0"
                            Content="Price Check"
                            Foreground="White" />
                        <Button
                            Height="40"
                            Background="Transparent"
                            BorderThickness="0"
                            Content="Help"
                            Foreground="White" />
                        <Button
                            Height="40"
                            Background="Transparent"
                            BorderThickness="0"
                            Content="About"
                            Foreground="White" />

                    </StackPanel>

                    <!--  RIGHT CONTENT  -->
                    <Border
                        Grid.Column="1"
                        Margin="10"
                        Padding="16"
                        Background="#3A3A3A"
                        CornerRadius="4">

                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="White"
                            Text="Select a tab" />

                    </Border>

                </Grid>

            </Grid>
        </Border>

    </Grid>
</UserControl>

<UserControl
    x:Class="D2RCompanion.UI.Views.HomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:D2RCompanion.UI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <!--  NAV  -->
            <ColumnDefinition Width="200" />
            <!--  CONTENT  -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  ================= NAV =================  -->
        <StackPanel Grid.Column="0">
            <Button Command="{Binding ShowSettingsCommand}" Content="Settings" />
            <Button Command="{Binding ShowTraderieCommand}" Content="Traderie" />
        </StackPanel>

    </Grid>
</UserControl>

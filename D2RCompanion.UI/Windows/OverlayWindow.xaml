<Window
    x:Class="D2RCompanion.UI.Windows.OverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:D2RCompanion.UI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:D2RCompanion.UI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:D2RCompanion.UI.Windows"
    Title="OverlayWindow"
    Width="800"
    Height="600"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowState="Maximized"
    WindowStyle="None"
    mc:Ignorable="d">

    <!--  Fullscreen Dark Overlay  -->
    <Grid x:Name="Root" Background="#80000000">

        <!--  =============== CONTENT ===============  -->
        <ContentControl Content="{Binding CurrentViewModel}" />

        <!--  =============== TRADERIE WEB VIEW ===============  -->
        <!--  =============== Appended On Load ================  -->

    </Grid>
</Window>

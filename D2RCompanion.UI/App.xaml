<Application
    x:Class="D2RCompanion.UI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:D2RCompanion.UI.Converters"
    xmlns:local="clr-namespace:D2RCompanion.UI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--  Core styles  -->
                <ResourceDictionary Source="/Styles/Styles.xaml" />

                <!--  Templates (THIS is your navigation engine)  -->
                <ResourceDictionary Source="/Resources/Templates/ViewTemplates.xaml" />

            </ResourceDictionary.MergedDictionaries>

            <!--  Only truly global singletons  -->
            <conv:IstPriceConverter x:Key="IstPriceConverter" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>

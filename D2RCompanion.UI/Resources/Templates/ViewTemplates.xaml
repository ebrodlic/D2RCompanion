<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:D2RCompanion.UI.Views"
    xmlns:vm="clr-namespace:D2RCompanion.UI.ViewModels">
    <!--  HOME  -->
    <DataTemplate DataType="{x:Type vm:HomeViewModel}">
        <views:HomeView />
    </DataTemplate>

    <!--  SETTINGS  -->
    <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
        <views:SettingsView />
    </DataTemplate>

    <!--  PRICING (center mode)  -->
    <DataTemplate DataType="{x:Type vm:PriceCheckViewModel}">
        <views:PriceCheckView />
    </DataTemplate>
</ResourceDictionary>
